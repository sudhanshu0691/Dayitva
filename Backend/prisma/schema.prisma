// ============================================================
// Decentralized TenderChain - Prisma Schema (PostgreSQL)
// Each role (Vendor, Officer, Auditor) has its own independent
// registration table with full auth capabilities
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- Enums ---

enum KYCStatus {
  Pending
  UnderReview
  Approved
  Rejected
}

enum TenderStatus {
  Draft
  Open
  Closed
  UnderEvaluation
  Awarded
  Cancelled
}

enum BidStatus {
  Submitted
  Revealed
  Evaluated
  Withdrawn
}

enum NotificationCategory {
  tender
  bid
  kyc
  system
}

enum TxType {
  TENDER_PUBLISHED
  BID_SUBMITTED
  BID_REVEALED
  WINNER_DECLARED
  WALLET_CONNECTED
  KYC_APPROVED
  KYC_REJECTED
}

enum TxStatus {
  success
  pending
  failed
}

enum AuditIconType {
  created
  published
  bid_submitted
  evaluation
  completed
}

enum DisputeStatus {
  Open
  UnderReview
  Resolved
  Dismissed
}

enum VerificationStatus {
  Pending
  Approved
  Rejected
  Blacklisted
  Suspicious
  ReVerificationRequired
}

enum FraudSeverity {
  Low
  Medium
  High
  Critical
}

enum FraudStatus {
  Open
  Investigating
  Confirmed
  Dismissed
}

model Vendor {
  id                  String    @id @default(cuid())
  name                String
  email               String    @unique
  mobile              String?
  passwordHash        String?
  role                String    @default("vendor")
  walletAddress       String?   @unique
  kycStatus           KYCStatus @default(Pending)
  kycDocuments        String?
  kycRemarks          String?
  kycReviewedBy       String?
  kycReviewedAt       DateTime?
  kycSubmittedAt      DateTime?
  companyName         String?
  regNumber           String?
  pan                 String?
  gst                 String?
  turnover            String?
  itrYears            String?
  solvencyCertificate String?
  experienceScore     Float?
  documentsIpfs       String?
  emailVerified       Boolean   @default(false)
  deviceInfo          String?
  ipAddress           String?
  profileImage        String?
  isActive            Boolean   @default(true)
  lastLogin           DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  bids                Bid[]
  refreshTokens       VendorRefreshToken[]
  kycRequests         VendorKYCRequest[]
  notifications       Notification[]
  @@map("vendors")
}

model VendorRefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  vendorId  String
  vendor    Vendor   @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
  @@map("vendor_refresh_tokens")
}

model Officer {
  id              String    @id @default(cuid())
  name            String
  email           String    @unique
  mobile          String?
  passwordHash    String?
  role            String    @default("officer")
  walletAddress   String?   @unique
  kycStatus       KYCStatus @default(Pending)
  kycDocuments    String?
  kycRemarks      String?
  kycReviewedBy   String?
  kycReviewedAt   DateTime?
  kycSubmittedAt  DateTime?
  designation     String?
  ministry        String?
  ministryCode    String?
  permissions     String?
  emailVerified   Boolean   @default(false)
  deviceInfo      String?
  ipAddress       String?
  profileImage    String?
  isActive        Boolean   @default(true)
  lastLogin       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  tenders         Tender[]
  refreshTokens   OfficerRefreshToken[]
  kycRequests     OfficerKYCRequest[]
  notifications   Notification[]
  @@map("officers")
}

model OfficerRefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  officerId String
  officer   Officer  @relation(fields: [officerId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
  @@map("officer_refresh_tokens")
}

model Auditor {
  id             String   @id @default(cuid())
  fullName       String
  officialEmail  String   @unique
  employeeId     String   @unique
  department     String
  phoneNumber    String?
  passwordHash   String
  role           String   @default("auditor")
  profileImage   String?
  isActive       Boolean  @default(true)
  lastLogin      DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  refreshTokens      AuditorRefreshToken[]
  verifications      Verification[]
  blacklistActions   BlacklistEntry[]
  activityLogs       AuditorActivityLog[]
  notifications      AuditorNotification[]
  reviewedVendorKYC  VendorKYCRequest[]
  reviewedOfficerKYC OfficerKYCRequest[]
  fraudResolutions   FraudFlag[]
  @@map("auditors")
}

model AuditorRefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  auditorId String
  auditor   Auditor  @relation(fields: [auditorId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
  @@map("auditor_refresh_tokens")
}

model Nonce {
  id            String   @id @default(cuid())
  walletAddress String
  nonce         String
  used          Boolean  @default(false)
  expiresAt     DateTime
  createdAt     DateTime @default(now())
  @@map("nonces")
}

model VendorKYCRequest {
  id              String             @id @default(cuid())
  vendorId        String
  vendor          Vendor             @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  documents       String
  documentTypes   String
  status          VerificationStatus @default(Pending)
  remarks         String?
  reviewedById    String?
  reviewedBy      Auditor?           @relation(fields: [reviewedById], references: [id])
  reviewedAt      DateTime?
  submissionCount Int                @default(1)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  @@map("vendor_kyc_requests")
}

model OfficerKYCRequest {
  id              String             @id @default(cuid())
  officerId       String
  officer         Officer            @relation(fields: [officerId], references: [id], onDelete: Cascade)
  documents       String
  documentTypes   String
  status          VerificationStatus @default(Pending)
  remarks         String?
  reviewedById    String?
  reviewedBy      Auditor?           @relation(fields: [reviewedById], references: [id])
  reviewedAt      DateTime?
  submissionCount Int                @default(1)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  @@map("officer_kyc_requests")
}

model Verification {
  id                  String             @id @default(cuid())
  entityId            String
  entityType          String
  documentType        String?
  status              VerificationStatus @default(Pending)
  remarks             String?
  isFraudFlagged      Boolean            @default(false)
  fraudReason         String?
  blacklistStatus     Boolean            @default(false)
  reVerificationCount Int                @default(0)
  reviewedById        String?
  reviewedBy          Auditor?           @relation(fields: [reviewedById], references: [id])
  verificationDate    DateTime?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  @@map("verifications")
}

model BlacklistEntry {
  id          String   @id @default(cuid())
  entityId    String
  entityType  String
  reason      String
  addedById   String
  addedBy     Auditor  @relation(fields: [addedById], references: [id])
  isPermanent Boolean  @default(false)
  removedAt   DateTime?
  createdAt   DateTime @default(now())
  @@map("blacklist_entries")
}

model FraudFlag {
  id           String        @id @default(cuid())
  entityId     String
  entityType   String
  flagType     String
  severity     FraudSeverity @default(Medium)
  status       FraudStatus   @default(Open)
  description  String
  evidence     String?
  detectedBy   String?
  detectedAt   DateTime      @default(now())
  resolvedAt   DateTime?
  resolvedById String?
  resolvedBy   Auditor?      @relation(fields: [resolvedById], references: [id])
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  @@map("fraud_flags")
}

model AuditorActivityLog {
  id          String   @id @default(cuid())
  auditorId   String
  auditor     Auditor  @relation(fields: [auditorId], references: [id], onDelete: Cascade)
  actionType  String
  description String?
  targetId    String?
  targetType  String?
  ipAddress   String?
  metadata    String?
  createdAt   DateTime @default(now())
  @@map("auditor_activity_logs")
}

model AuditorNotification {
  id        String   @id @default(cuid())
  auditorId String
  auditor   Auditor  @relation(fields: [auditorId], references: [id], onDelete: Cascade)
  title     String
  message   String
  read      Boolean  @default(false)
  actionUrl String?
  type      String?
  createdAt DateTime @default(now())
  @@map("auditor_notifications")
}

model Tender {
  id            String       @id @default(cuid())
  title         String
  description   String
  ipfsHash      String?
  budget        Float
  deadline      DateTime
  status        TenderStatus @default(Draft)
  ministry      String?
  msmeQuota     Boolean      @default(false)
  criteria      String?
  minScore      Float?       @default(0)
  txHash        String?
  blockNumber   Int?
  winnerAddress String?
  winnerPrice   Float?
  winnerName    String?
  officerId    String
  officer      Officer      @relation(fields: [officerId], references: [id])
  bids         Bid[]
  tenderFiles  TenderFile[]
  auditLogs    AuditLog[]
  disputes     Dispute[]
  transactions BlockchainTx[]
  createdAt  DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@map("tenders")
}

model TenderFile {
  id         String   @id @default(cuid())
  name       String
  size       String
  hash       String
  uploadedAt DateTime @default(now())
  tenderId   String
  tender     Tender   @relation(fields: [tenderId], references: [id], onDelete: Cascade)
  @@map("tender_files")
}

model Bid {
  id                  String    @id @default(cuid())
  price               Float?
  encryptedBidHash    String?
  bidHash             String?
  priceScore          Float?
  financialStrength   Float?
  pastExperience      Float?
  performanceFeedback Float?
  technicalCapability Float?
  compliance          Float?
  proposalQuality     Float?
  totalScore          Float?
  status              BidStatus @default(Submitted)
  txHash              String?
  blockNumber         Int?
  tenderId  String
  tender    Tender   @relation(fields: [tenderId], references: [id], onDelete: Cascade)
  vendorId  String
  vendor    Vendor   @relation(fields: [vendorId], references: [id])
  submittedAt DateTime @default(now())
  revealedAt  DateTime?
  @@map("bids")
}

model AuditLog {
  id          String        @id @default(cuid())
  title       String
  description String
  timestamp   DateTime      @default(now())
  txHash      String?
  iconType    AuditIconType @default(created)
  tenderId    String
  tender      Tender        @relation(fields: [tenderId], references: [id], onDelete: Cascade)
  officerId   String?
  @@map("audit_logs")
}

model Notification {
  id         String             @id @default(cuid())
  title      String
  message    String
  category   NotificationCategory @default(system)
  read       Boolean            @default(false)
  actionUrl  String?
  entityId   String?
  entityType String?
  userId     String?
  vendorId   String?
  vendor     Vendor?            @relation(fields: [vendorId], references: [id])
  officerId  String?
  officer    Officer?           @relation(fields: [officerId], references: [id])
  createdAt  DateTime           @default(now())
  @@map("notifications")
}

model Otp {
  id         String   @id @default(cuid())
  email      String
  otp        String
  type       String
  entityType String
  expiresAt  DateTime
  used       Boolean  @default(false)
  createdAt  DateTime @default(now())
  @@map("otps")
}

model BlockchainTx {
  id            String   @id @default(cuid())
  txHash        String   @unique
  blockNumber   Int?
  gasFee        String?
  timestamp     DateTime @default(now())
  walletAddress String
  type          TxType
  status        TxStatus @default(pending)
  metadata      String?
  chainId       Int?
  etherscanUrl  String?
  tenderId      String?
  tender        Tender?  @relation(fields: [tenderId], references: [id])
  entityId      String?
  entityType    String?
  @@map("blockchain_txs")
}

model ActivityLog {
  id          String   @id @default(cuid())
  entityId    String?
  entityType  String
  actionType  String
  description String
  metadata    String?
  ipAddress   String?
  createdAt   DateTime @default(now())
  @@map("activity_logs")
}

model Dispute {
  id         String        @id @default(cuid())
  text       String
  status     DisputeStatus @default(Open)
  tenderId   String
  tender     Tender        @relation(fields: [tenderId], references: [id], onDelete: Cascade)
  entityId   String?
  entityType String?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  @@map("disputes")
}