# ============================================================
# Decentralized TenderChain - Environment Variables
# Ganache Local Blockchain via MetaMask
# ============================================================

# Server Configuration
PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/tenderchain

# JWT Authentication
JWT_SECRET=your-jwt-secret-change-in-production
JWT_REFRESH_SECRET=your-jwt-refresh-secret-change-in-production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Pinata (IPFS)
PINATA_API_KEY=your-pinata-api-key
PINATA_SECRET_KEY=your-pinata-secret-key
PINATA_JWT=your-pinata-jwt

# AWS S3 (Optional - for document storage)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
AWS_REGION=ap-south-1
AWS_S3_BUCKET=tenderchain-documents
AWS_S3_ENDPOINT=
AWS_S3_PUBLIC_URL=
AWS_S3_FORCE_PATH_STYLE=false

# ============================================================
# Ganache Local Blockchain (via MetaMask)
# ============================================================
# Ganache RPC URL (default: http://127.0.0.1:7545)
BLOCKCHAIN_RPC_URL=http://127.0.0.1:7545

# Ganache Chain ID (default: 1337)
BLOCKCHAIN_CHAIN_ID=1337

# 👇 CONTRACT ADDRESS - Deploy using Remix IDE + MetaMask
# After deploying the contract, paste the address here:
CONTRACT_ADDRESS=0xYourDeployedContractAddressHere

# Optional block explorer (leave empty for Ganache)
BLOCKCHAIN_EXPLORER_URL=

# Socket.io
SOCKET_CORS_ORIGIN=http://localhost:3000

# Email (SMTP)
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=

# Gmail (Alternative to SMTP)
GMAIL_USER=
GMAIL_APP_PASSWORD=

# Logging
LOG_LEVEL=debug