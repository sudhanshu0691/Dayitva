# ===========================================
# Decentralized TenderChain - Environment Config
# ===========================================

# --- Database (PostgreSQL - Supabase Free Tier) ---
DATABASE_URL="postgresql://postgres:password@db.xxxxx.supabase.co:5432/postgres?schema=public"

# --- JWT Authentication ---
JWT_SECRET="your-jwt-secret-key-change-in-production-min-32-chars"
JWT_REFRESH_SECRET="your-jwt-refresh-secret-key-change-in-production-min-32-chars"
JWT_ACCESS_EXPIRY="15m"       # Access token expiry
JWT_REFRESH_EXPIRY="7d"      # Refresh token expiry

# --- Server ---
PORT=4000
NODE_ENV="development"
FRONTEND_URL="http://localhost:3000"

# --- Pinata (IPFS Free Tier) ---
PINATA_API_KEY="your-pinata-api-key"
PINATA_SECRET_KEY="your-pinata-secret-key"

# --- AWS S3 (Free Tier) ---
AWS_ACCESS_KEY_ID="your-aws-access-key"
AWS_SECRET_ACCESS_KEY="your-aws-secret-key"
AWS_SESSION_TOKEN="" # required when using temporary STS credentials
AWS_REGION="ap-south-1"
AWS_S3_BUCKET="tenderchain-documents"
AWS_S3_ENDPOINT="" # optional for S3-compatible storage (R2/MinIO/Spaces)
AWS_S3_PUBLIC_URL="" # optional CDN/public base URL for returned file links
AWS_S3_FORCE_PATH_STYLE="false" # set true for MinIO/localstack and some S3-compatible providers

# --- Ethereum / Blockchain (Local Ganache) ---
ETH_RPC_URL="http://127.0.0.1:7545"
ETH_CHAIN_ID=1337
CONTRACT_ADDRESS="YOUR_DEPLOYED_CONTRACT_ADDRESS"
OFFICER_PRIVATE_KEY="YOUR_GANACHE_PRIVATE_KEY"
VENDOR_PRIVATE_KEY=""
BLOCKCHAIN_SIMULATION_MODE="true"

# --- Socket.io (Realtime) ---
SOCKET_CORS_ORIGIN="http://localhost:3000"

# --- Email (OTP Verification) ---
# Option 1: SMTP (any provider)
EMAIL_HOST="smtp.gmail.com"
EMAIL_PORT=587
EMAIL_USER="your-email@gmail.com"
EMAIL_PASS="your-app-password"

# Option 2: Gmail App Password (simpler)
GMAIL_USER="your-email@gmail.com"
GMAIL_APP_PASSWORD="your-16-char-app-password"

# --- Logging ---
LOG_LEVEL="debug"              # error | warn | info | debug
